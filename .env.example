# 环境变量配置示例
# 将此文件复制为 .env.local 用于本地开发，生产环境在 Vercel Dashboard 中配置

# 微信公众号后台配置的 Token（字母+数字，3-32位）
WECHAT_TOKEN=MySparkBot2026

# 讯飞控制台获取的 APIpassword（Bearer Token）
# 获取地址：https://console.xfyun.cn/services/bmx1
SPARK_API_PASSWORD=your_api_password_here

# 是否开启星火联网搜索（true/false，默认 false）
ENABLE_WEB_SEARCH=false
