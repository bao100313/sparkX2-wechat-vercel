{
  "version": 2,
  "name": "spark-wechat",
  "functions": {
    "api/wechat.js": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "routes": [
    {
      "src": "/wechat",
      "dest": "/api/wechat.js"
    },
    {
      "src": "/api/wechat",
      "dest": "/api/wechat.js"
    },
    {
      "src": "/",
      "dest": "/api/wechat.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
